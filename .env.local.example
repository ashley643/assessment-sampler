# ─── Claude / Anthropic API ─────────────────────────────────────────────────
# Required for AI narrative writing features
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google APIs ─────────────────────────────────────────────────────────────
# Option A: Service Account (for server-side export to Google Slides)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Slides API + Google Sheets API
# Download the JSON key and paste it as a single-line JSON string below
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Option B: OAuth2 (pass user access_token in export request body)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
